# Floor-Plan Studio — copy to app/.env and fill in (app/.env is gitignored; never commit keys)

# REQUIRED — all LLM features (ops, comps, vision) run on YOUR Claude subscription via the
# Claude Agent SDK. One-time: run `claude setup-token` (Pro/Max) and paste the 1-year token here.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# DO NOT set ANTHROPIC_API_KEY — it outranks the subscription token and bills paid API credits.

# P5 rent comparables web search (search provider swappable)
TAVILY_API_KEY=tvly-...

# Demo narration — Deepgram Aura TTS for make demo (optional; silent captions without it)
DEEPGRAM_API_KEY=...
